PORT=3000

# Email que recebe automaticamente todas as provas finalizadas.
RESULT_RECIPIENT_EMAIL=rodrigo.melo@totallpi.co

# Avaliacao por IA das questoes abertas.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-mini

# Microsoft Exchange / Graph.
# Requer App Registration com Microsoft Graph Application permission: Mail.Send.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER=rodrigo.melo@totallpi.co

# Alternativas opcionais, usadas apenas se Microsoft Graph nao estiver configurado.
RESEND_API_KEY=
RESULT_FROM_EMAIL=Totall Prova SDR <provas@totallpi.co>
RESULT_WEBHOOK_URL=
